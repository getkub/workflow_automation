{
    "mcpServers": {
        "n8n-mcp": {
            "command": "node",
            "args": [
                "/opt/homebrew/lib/node_modules/n8n-mcp/dist/mcp/index.js"
            ],
            "env": {
                "MCP_MODE": "stdio",
                "LOG_LEVEL": "error",
                "DISABLE_CONSOLE_OUTPUT": "true",
                "N8N_API_URL": "http://localhost:5678",
                "N8N_BASE_URL": "http://localhost:5678",
                "N8N_API_KEY": "xxxxxxxx"
            }
        }
    }
}